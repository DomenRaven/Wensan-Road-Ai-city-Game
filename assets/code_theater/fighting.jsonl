{"delay_ms": 713, "text": "# core/fighter.gd — 战斗动作", "highlight": false}
{"delay_ms": 713, "text": "extends CharacterBody2D", "highlight": false}
{"delay_ms": 624, "text": "", "highlight": false}
{"delay_ms": 713, "text": "func try_move(direction: float) -> void:", "highlight": false}
{"delay_ms": 980, "text": "    var speed = FightConstants.float_val(\"player_speed\", 200)", "highlight": true, "anchor_id": "player_speed"}
{"delay_ms": 624, "text": "    velocity.x = direction * speed", "highlight": false}
{"delay_ms": 624, "text": "", "highlight": false}
{"delay_ms": 980, "text": "func try_light_attack() -> bool:", "highlight": true, "anchor_id": "light_punch"}
{"delay_ms": 624, "text": "    return _try_attack(ActionState.ATTACK1)", "highlight": false}
{"delay_ms": 624, "text": "", "highlight": false}
{"delay_ms": 980, "text": "func try_block() -> void:", "highlight": true, "anchor_id": "block"}
{"delay_ms": 624, "text": "    _set_state(ActionState.BLOCK)", "highlight": false}
{"delay_ms": 624, "text": "", "highlight": false}
{"delay_ms": 980, "text": "func try_ultimate() -> bool:", "highlight": true, "anchor_id": "special"}
{"delay_ms": 624, "text": "    return arena.call(\"request_ultimate\", self)", "highlight": false}
{"delay_ms": 624, "text": "", "highlight": false}
{"delay_ms": 713, "text": "# core/fight_arena.gd — 结算伤害", "highlight": false}
{"delay_ms": 713, "text": "func resolve_hit(attacker, defender, move_id: String) -> void:", "highlight": false}
{"delay_ms": 802, "text": "    var raw_damage = combat.get(\"light_damage\", 5)", "highlight": true, "anchor_id": "light_damage"}
{"delay_ms": 713, "text": "    if move_id == \"heavy\":", "highlight": false}
{"delay_ms": 802, "text": "        raw_damage = combat.get(\"heavy_damage\", 15)", "highlight": true, "anchor_id": "heavy_damage"}
{"delay_ms": 624, "text": "    if defender_blocking:", "highlight": false}
{"delay_ms": 713, "text": "        final_damage = int(floor(raw_damage * reduction))", "highlight": true, "anchor_id": "block"}
{"delay_ms": 624, "text": "", "highlight": false}
{"delay_ms": 713, "text": "# core/player_fighter.gd — 输入映射", "highlight": false}
{"delay_ms": 713, "text": "func handle_input(..., just_light, just_heavy, block_held, just_ultimate):", "highlight": false}
