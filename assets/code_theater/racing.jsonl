{"delay_ms": 713, "text": "func _process(delta: float) -> void:", "highlight": false}
{"delay_ms": 802, "text": "    if Input.is_action_pressed(\"skill\"):", "highlight": true, "anchor_id": "boost"}
{"delay_ms": 624, "text": "        _current_speed += _acceleration * delta", "highlight": true, "anchor_id": "boost"}
{"delay_ms": 624, "text": "    _current_speed = clampf(_current_speed, 0.0, _max_speed)", "highlight": false}
